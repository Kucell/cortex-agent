{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cortex Agent Decision Index",
  "type": "object",
  "required": ["decisions"],
  "properties": {
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["decision_id", "path", "type", "status", "gate_action", "resource_ref", "updated_at"],
        "properties": {
          "decision_id": { "type": "string", "pattern": "^D-[A-Za-z0-9][A-Za-z0-9._-]*$" },
          "path": { "type": "string", "pattern": "^\\.agent/decisions/D-[^/]+\\.json$" },
          "type": { "type": "string", "enum": ["approval", "architecture", "merge", "release", "risk"] },
          "status": { "type": "string", "enum": ["open", "approved", "rejected", "revision_requested", "canceled", "superseded"] },
          "gate_action": { "type": "string", "enum": ["architecture", "merge", "release", "destructive", "credential", "external_side_effect"] },
          "resource_ref": { "type": "string", "minLength": 1 },
          "updated_at": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
