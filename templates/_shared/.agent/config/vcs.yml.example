# vcs.yml — VCS backend + repo reference.
# Drop into .agent/config/vcs.yml on first use; this file is the
# distributed example (no real values).
#
# backend: one of gitea | github | gitlab  (each ships as a backend
# .js under .agent/skills/vcs-pr/scripts/backends/)
# host:    base URL of the VCS instance
# token_ref: name of a secret registered in config/secrets.yml; vcs-pr
#           invokes `secrets get --ref <token_ref> --no-mask --gate user`
#           internally to fetch the Authorization header. The agent
#           never sees this value.
backend: gitea
host: "http://192.168.2.110:3000"
token_ref: gitea-pr

default:
  org: SamkoonHMI
  repo: SamHMI
  base_branch: main
