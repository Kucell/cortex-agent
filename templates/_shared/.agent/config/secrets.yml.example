# secrets.yml — credential storage reference.
# Drop into .agent/config/secrets.yml on first use; this file is the
# distributed example (no real values).
#
# backend: one of keychain | secret-service | file-gpg | env
#   - keychain       — macOS default
#   - secret-service — Linux (libsecret via secret-tool(1))
#   - file-gpg       — gpg-agent symmetric AES, cross-platform
#   - env            — read-only fallback for CI (process.env[CORTEX_SECRET_*])
backend: keychain

namespace: SamHMI

# Each ref is a stable symbolic name agents reference as `secret://<ref>`.
# The actual plaintext value lives inside the active backend; framework
# resolves it on demand and never returns it to agent-visible logs.
secrets:
  - ref: gitea-pr
    service: gitea-192.168.2.110-codex-samhmi-pr
    account: xueyq
    description: Gitea API token (read/write repository scope).
  - ref: github-copilot
    service: github-copilot-xueyq
    description: GitHub Copilot PAT (project automation).
