{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cortex-agent.local/schemas/evidence-ref.schema.json",
  "title": "Cortex Agent Evidence Reference",
  "type": "object",
  "required": ["evidence_id", "kind", "ref", "producer", "created_at", "redacted", "availability"],
  "properties": {
    "evidence_id": { "type": "string", "pattern": "^EV-[A-Za-z0-9][A-Za-z0-9._-]*$" },
    "kind": { "type": "string", "enum": ["command", "validation", "artifact", "runtime", "log_cursor", "manual"] },
    "ref": { "type": "string", "minLength": 1 },
    "producer": { "type": "string", "minLength": 1 },
    "resource_id": { "type": ["string", "null"] },
    "run_id": { "type": ["string", "null"] },
    "session_id": { "type": ["string", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "redacted": { "const": true },
    "availability": { "type": "string", "enum": ["available", "rotated", "expired", "unavailable"] },
    "summary": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
