{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cortex Agent Guided Review Artifact",
  "type": "object",
  "required": ["type", "artifact_id", "task_id", "run_id", "session_id", "workspace_ids", "base_revision", "head_revision", "groups", "summary", "generated_at"],
  "properties": {
    "type": { "const": "guided_review" },
    "artifact_id": { "type": "string", "pattern": "^GR-" },
    "task_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "workspace_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^WS-" }, "uniqueItems": true },
    "base_revision": { "type": "string", "minLength": 7 },
    "head_revision": { "type": "string", "minLength": 7 },
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["group_id", "title", "intent", "files", "summary", "impact", "risk", "validation_refs", "follow_ups"],
        "properties": {
          "group_id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "intent": { "type": "string", "minLength": 1 },
          "files": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
          "summary": { "type": "string", "minLength": 1 },
          "impact": { "type": "string", "minLength": 1 },
          "risk": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "validation_refs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "follow_ups": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": ["group_count", "file_count", "risk_counts", "validation_ref_count", "follow_up_count"],
      "additionalProperties": false
    },
    "generated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
