{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cortex Agent Queue",
  "type": "object",
  "required": ["queue_id", "status", "items"],
  "properties": {
    "queue_id": { "type": "string" },
    "name": { "type": "string" },
    "status": { "type": "string", "enum": ["active", "paused", "drained"] },
    "concurrency_limit": { "type": "number" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id", "state"],
        "properties": {
          "task_id": { "type": "string" },
          "state": { "type": "string", "enum": ["queued", "running", "blocked", "done"] },
          "worktree_path": { "type": ["string", "null"] },
          "agent_id": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
