{
  "version": "0.2",
  "language": "en",
  "ignorePaths": [
    "node_modules",
    "dist",
    ".git",
    "templates",
    "docs/exec-plans/active",
    "docs/exec-plans/completed"
  ],
  "words": [
    "swiftlint",
    "frontmatter",
    "kucelleric",
    "techdebt",
    "linters",
    "config",
    "configs",
    "linter",
    "frontend",
    "backend",
    "metadata",
    "pipeline",
    "pipelines",
    "changelog",
    "changelogs",
    "npmrc",
    "tsbuildinfo",
    "untracked",
    "tracked",
    "precommit",
    "postcommit",
    "prepush",
    "readme",
    "readmes",
    "untracked",
    "rollout",
    "runtimes",
    "semver",
    "subagent",
    "subagents",
    "toolchain",
    "toolchains",
    "worktree",
    "worktrees",
    "workspace",
    "workspaces",
    "multiline"
  ],
  "ignoreRegExpList": [
    "/<!-- cspell:disable -->[\\s\\S]*?<!-- cspell:enable -->/g",
    "/```[\\s\\S]*?```/g",
    "`[^`]*`"
  ]
}
